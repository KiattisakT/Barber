generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ShopStatus {
  active
  inactive
}

enum StaffRole {
  barber
  tattoo_artist
  owner
}

enum StaffStatus {
  active
  inactive
}

enum ServiceCategory {
  barber
  tattoo
}

enum QueueSource {
  online
  walk_in
  admin
  tattoo
}

enum QueueStatus {
  confirmed
  checked_in
  in_progress
  completed
  pending_review
  contacted
  cancelled
  no_show
}

enum TattooRequestStatus {
  pending_review
  contacted
  confirmed
  cancelled
}

model Shop {
  id                 String              @id @default(cuid())
  slug               String              @unique
  name               String
  displayName        String
  phone              String?
  address            String?
  mapUrl             String?
  timezone           String              @default("Asia/Bangkok")
  status             ShopStatus          @default(active)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  staff              Staff[]
  services           Service[]
  customers          Customer[]
  queueItems         QueueItem[]
  tattooRequests     TattooRequest[]
  referenceImages    ReferenceImage[]
  businessHours      BusinessHours[]
  blockedTimes       BlockedTime[]
  dailyQueueCounters DailyQueueCounter[]
}

model Staff {
  id                      String          @id @default(cuid())
  shopId                  String
  name                    String
  role                    StaffRole
  phone                   String?
  isBookable              Boolean         @default(true)
  status                  StaffStatus     @default(active)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  shop                    Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  queueItems              QueueItem[]
  preferredTattooRequests TattooRequest[]
  businessHours           BusinessHours[]
  blockedTimes            BlockedTime[]

  @@index([shopId])
}

model Service {
  id              String          @id @default(cuid())
  shopId          String
  category        ServiceCategory
  name            String
  description     String?
  priceLabel      String
  priceAmount     Decimal?        @db.Decimal(10, 2)
  durationMinutes Int
  bufferMinutes   Int             @default(0)
  image           String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  shop            Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  queueItems      QueueItem[]

  @@index([shopId, category])
}

model Customer {
  id             String          @id @default(cuid())
  shopId         String
  name           String
  phone          String
  lineId         String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  shop           Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  queueItems     QueueItem[]
  tattooRequests TattooRequest[]

  @@index([shopId, phone])
}

model QueueItem {
  id                   String       @id @default(cuid())
  shopId               String
  queueNumber          String
  queueDate            DateTime     @db.Date
  customerId           String
  serviceId            String
  staffId              String
  source               QueueSource
  status               QueueStatus
  startsAt             DateTime?
  endsAt               DateTime?
  estimatedWaitMinutes Int          @default(0)
  queueAhead           Int          @default(0)
  bookingCode          String
  customerNote         String?
  internalNote         String?
  tattooRequestId      String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  shop                 Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer             Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  service              Service      @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  staff                Staff        @relation(fields: [staffId], references: [id], onDelete: Restrict)
  tattooRequest        TattooRequest? @relation(fields: [tattooRequestId], references: [id], onDelete: SetNull)

  @@unique([shopId, queueDate, queueNumber])
  @@unique([shopId, bookingCode])
  @@index([shopId, queueDate, status])
  @@index([staffId, startsAt, endsAt])
}

model TattooRequest {
  id                 String              @id @default(cuid())
  shopId             String
  queueNumber        String
  customerId         String
  preferredStaffId   String?
  status             TattooRequestStatus @default(pending_review)
  placement          String
  sizeEstimate       String
  budgetEstimate     String?
  preferredDateText  String?
  description        String
  internalNote       String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  shop               Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer           Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  preferredStaff     Staff?              @relation(fields: [preferredStaffId], references: [id], onDelete: SetNull)
  referenceImages    ReferenceImage[]
  queueItems         QueueItem[]

  @@unique([shopId, queueNumber])
  @@index([shopId, status])
}

model ReferenceImage {
  id              String         @id @default(cuid())
  shopId          String
  tattooRequestId String
  url             String
  fileName        String
  mimeType        String
  sizeBytes       Int
  createdAt       DateTime       @default(now())

  shop            Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  tattooRequest   TattooRequest  @relation(fields: [tattooRequestId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([tattooRequestId])
}

model BusinessHours {
  id        String   @id @default(cuid())
  shopId    String
  staffId   String?
  dayOfWeek Int
  opensAt   String
  closesAt  String
  isClosed  Boolean  @default(false)

  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  staff     Staff?   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([shopId, staffId, dayOfWeek])
  @@index([shopId, dayOfWeek])
}

model BlockedTime {
  id        String   @id @default(cuid())
  shopId    String
  staffId   String
  startsAt  DateTime
  endsAt    DateTime
  reason    String
  createdAt DateTime @default(now())

  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([shopId, startsAt, endsAt])
  @@index([staffId, startsAt, endsAt])
}

model DailyQueueCounter {
  id          String   @id @default(cuid())
  shopId      String
  queueDate   DateTime @db.Date
  prefix      String
  lastNumber  Int      @default(0)
  updatedAt   DateTime @updatedAt

  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, queueDate, prefix])
}
